# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/dynamic-mcq-system
MONGODB_TEST_URI=mongodb://localhost:27017/dynamic-mcq-system-test

# Server Configuration
PORT=3000
NODE_ENV=development

# AI Service Configuration (Multi-Tier Fallback System)
# The system will try these in order: Groq -> Gemini -> Templates

# Groq API (Recommended - Fast & Free)
# Get your free API key: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Gemini API (Alternative - Google AI)
# Get your free API key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API (Legacy - Not currently used)
OPENAI_API_KEY=your_openai_api_key_here

AI_SERVICE_TIMEOUT=30000
# Redis Configuration (for caching)
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET='363f41022954e2004588043d92c0ea59188586c2912d054e96c0bf140345282ac49daa3914e9f63fa65fa937b5433bbd5c9308f58490701241a89f120761f1d2'
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET='c3bdb96464f5c3adcfca2d1d451ba55de8a97d20d0d6aad0c3bc996beb0b8b8cc936055e785247407bb9adf0619433851c9542042c1795d5f9828a201b387cf4'
JWT_REFRESH_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
